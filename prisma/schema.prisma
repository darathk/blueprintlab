generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Athlete {
  id               String      @id @default(uuid())
  name             String
  email            String      @unique
  role             String      @default("athlete") // 'coach' or 'athlete'
  coachId          String? // If role is 'athlete', this links them to their coach
  coach            Athlete?    @relation("CoachToAthlete", fields: [coachId], references: [id])
  guidedAthletes   Athlete[]   @relation("CoachToAthlete")
  nextMeetName     String?
  nextMeetDate     String?
  weightClass      Float?   // kg, e.g. 83.0
  gender           String?  // "male" or "female"
  periodization    Json?
  meetAttempts     Json?
  pastMeets        Json?
  liftTargets      Json?     // { liftName: { timeToPeak: weeks, stressTarget: number } }
  trainingSchedule String?   // Preferred training schedule (e.g., "Mon, Wed, Fri")
  programs         Program[]
  reports          Report[]
  readiness        Readiness[]
  sentMessages     Message[]   @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  pushSubscriptions PushSubscription[]
  programTemplates  ProgramTemplate[]  @relation("CoachTemplates")
  coachNotes        CoachNote[]        @relation("CoachNotes")
  athleteNotes      CoachNote[]        @relation("AthleteNotes")

  @@index([coachId])
}

model Program {
  id        String   @id @default(uuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id])
  name      String
  startDate String
  endDate   String?
  weeks     Json // Storing complex nested structure easily
  status    String   @default("active")
  createdAt DateTime @default(now())
  logs      Log[]

  @@index([athleteId, status])
}

model Log {
  id        String  @id @default(uuid())
  programId String
  program   Program @relation(fields: [programId], references: [id])
  sessionId String
  date      String
  exercises Json // Completed sets, reps, rpes

  @@index([programId, sessionId])
}

model Report {
  id        String   @id @default(uuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  created   DateTime @default(now())
  status    String   @default("Complete")
  config    Json // Stores report parameters
}

model CustomExercise {
  id       String  @id @default(uuid())
  name     String  @unique
  category String
  parent   String
  isCustom Boolean @default(true)
}

model Readiness {
  id        String   @id @default(uuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  programId String?
  date      String
  scores    Json
  timestamp DateTime @default(now())

  @@index([athleteId, date])
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  sender     Athlete   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Athlete   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  mediaUrl   String?
  mediaType  String?
  createdAt  DateTime  @default(now())
  read       Boolean   @default(false)
  replyToId  String?
  replyTo    Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    Message[] @relation("MessageReplies")
  reactions  Json?     // Storing emoji reactions as map: { emoji: [userIds] }

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, read])
}

model PushSubscription {
  id        String   @id @default(uuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([athleteId])
}

model ProgramTemplate {
  id          String   @id @default(uuid())
  coachId     String
  coach       Athlete  @relation("CoachTemplates", fields: [coachId], references: [id], onDelete: Cascade)
  name        String
  description String?
  weeks       Json
  tags        Json?    // string[] for categorization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coachId])
}

model CoachNote {
  id        String   @id @default(uuid())
  coachId   String
  coach     Athlete  @relation("CoachNotes", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   Athlete  @relation("AthleteNotes", fields: [athleteId], references: [id], onDelete: Cascade)
  content   String
  category  String   @default("general") // general, injury, cues, preferences
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId, athleteId])
}
